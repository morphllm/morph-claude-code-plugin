{
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun install --silent --cwd ${CLAUDE_PLUGIN_ROOT} && bun ${CLAUDE_PLUGIN_ROOT}/src/hooks/pre-compact.ts"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bun install --silent --cwd ${CLAUDE_PLUGIN_ROOT} && bun ${CLAUDE_PLUGIN_ROOT}/src/hooks/session-start.ts"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/hooks/subagent-start.ts"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun ${CLAUDE_PLUGIN_ROOT}/src/hooks/user-prompt-submit.ts"
          }
        ]
      }
    ]
  }
}
