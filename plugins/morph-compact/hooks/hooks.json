{
  "description": "Starts and stops the Morph compaction proxy alongside Claude Code",
  "hooks": {
    "Setup": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/start-proxy.sh\"",
            "timeout": 20
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop-proxy.sh\"",
            "timeout": 3
          }
        ]
      }
    ]
  }
}
